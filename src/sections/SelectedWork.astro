---
import { localePath } from '~/i18n/utils';
import type { Locale } from '~/i18n/utils';
import type { CaseRow } from '~/lib/fixtures';

interface Props {
  lang: Locale;
  cases: CaseRow[];
  head?: { title: string; em: string; link: string } | null;
}
const { lang, cases, head = null } = Astro.props;
const h = head ?? { title: 'selected work.', em: 'work', link: '2024 — 2026 / 12 cases' };
// Подставляем em внутри title как акцент: "selected <em>work</em>."
const titleLead = (h.title ?? '').replace(h.em + '.', '').replace(h.em, '');
---

<section class="work" id="work">
  <div class="work-head">
    <h2>{titleLead}<em>{h.em}</em>.</h2>
    <a href={localePath(lang, '/work')} class="work-all">{h.link} ↗</a>
  </div>
  <div class="work-grid">
    {cases.map((c, i) => (
      <a href={localePath(lang, '/work/' + c.slug)} class:list={['card', 'c' + (i + 1)]}>
        <div class="meta">
          <span>{String(i + 1).padStart(2, '0')} / {c.slug}</span>
          <span>{c.category}</span>
        </div>
        <div class="arr">↗</div>
        <h4>{c.title} — <span class="card-sub">{c.sub}</span></h4>
        {i === 4 && (
          <div class="chart">
            <svg viewBox="0 0 400 100" preserveAspectRatio="none">
              <polyline fill="none" stroke="#d6ff3d" stroke-width="1.5" points="0,70 30,60 60,68 90,40 120,50 150,30 180,42 210,20 240,28 270,12 300,22 330,8 360,18 400,5" />
              <polyline fill="none" stroke="#ff5a1f" stroke-width="1" opacity=".5" points="0,80 50,75 100,72 150,68 200,60 250,55 300,48 350,42 400,38" />
            </svg>
          </div>
        )}
      </a>
    ))}
  </div>
</section>
