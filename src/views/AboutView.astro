---
import '~/styles/pages/about.css';
import Layout from '~/layouts/Layout.astro';
import type { Locale } from '~/i18n/utils';
import { getPageAbout } from '~/lib/pocketbase';

import AboutHero from '~/sections/AboutHero.astro';
import Nums from '~/sections/Nums.astro';
import StorySection from '~/sections/StorySection.astro';
import FinalCta from '~/sections/FinalCta.astro';

interface Props { lang: Locale; }
const { lang } = Astro.props;

const page = await getPageAbout(lang);
const final = page?.final_meta;
---

<Layout lang={lang} active="about" withStickyCta={false} seo={page?.seo}>
  <div class="about">
    <AboutHero lang={lang} data={page?.hero} />
    <Nums items={page?.nums ?? []} />
    <StorySection story={page?.story} />
    <FinalCta lang={lang} meta={typeof final === 'string' ? final : null} />
  </div>
</Layout>
