---
import Layout from '~/layouts/Layout.astro';
import { localePath } from '~/i18n/utils';
import type { Locale } from '~/i18n/utils';

interface Props { lang: Locale; }
const { lang } = Astro.props;

const isRu = lang === 'ru';
---

<Layout title="About · impuls/studio" lang={lang} active="about" withStickyCta={false}>
  <section class="hero">
    <div class="crumbs">
      <a href={localePath(lang, '/')}>index</a><span>/</span><span style="color:var(--ink)">about</span>
    </div>

    <h1>
      we're <em>three</em> people<br />
      who got <span class="strike">tired</span> <em>obsessed</em><br />
      with crypto <em>UI</em>.
    </h1>

    <div class="hero-foot">
      <p>
        impuls / studio — {isRu ? 'небольшая независимая команда' : 'a small independent team'}: trader, designer & engineer.
        <span>
          {isRu
            ? 'Делаем продукты для тех, кто работает на рынке каждый день: терминалы, бот-инфра, лендинги под токен-лонч.'
            : 'We build products for people who live on the market: terminals, bot infra, token-launch landings.'}
        </span>
      </p>
      <div class="meta">
        <div>founded · <b>2024</b></div>
        <div>headcount · <b>3 + 2 freelance</b></div>
        <div>location · <b>remote · UTC+3</b></div>
        <div>status · <b style="color:var(--acid)">● accepting Q3 / 2026</b></div>
      </div>
    </div>
  </section>

  <div class="nums">
    <div class="num"><div class="v"><em>17</em></div><div class="k">shipped projects</div></div>
    <div class="num"><div class="v">2<em>.5</em></div><div class="k">years live</div></div>
    <div class="num"><div class="v"><em>$3M</em><sup>+</sup></div><div class="k">turnover on our products</div></div>
    <div class="num"><div class="v">12</div><div class="k">live in production</div></div>
    <div class="num"><div class="v"><em>0</em></div><div class="k">stock 3D blobs used</div></div>
  </div>

  <section class="s">
    <div class="s-grid">
      <div class="s-tag">[ 01 ] / story</div>
      <div class="s-body">
        <h2>{isRu ? 'как мы тут' : 'how we got'} <em>{isRu ? 'оказались' : 'here'}</em>.</h2>
        <p class="big">
          {isRu ? 'Мы начали со своей боли.' : 'We started with our own pain.'} <em>{isRu ? 'Трейдили' : 'We were trading'}</em>
          {isRu ? ' сами — и каждый раз бесили интерфейсы, в которых критическая цифра спрятана под аккордеоном.' : ' ourselves — and were constantly annoyed by interfaces where critical data hid behind an accordion.'}
        </p>
        <p>{isRu
          ? 'В 2024 собрали первый внутренний инструмент — бот с админкой для управления стратегией. Через месяц нас попросили сделать «то же самое, но для друга». Через три — пришёл первый платный проект.'
          : 'In 2024 we built our first internal tool — a bot with an admin to manage strategy. A month later we were asked to do "the same, but for a friend". Three months — first paid project.'}
        </p>
      </div>
    </div>
  </section>

  <section class="final">
    <h2>let's <em>talk</em>.</h2>
    <a href={localePath(lang, '/') + '#start'} class="cta">start a project ↗</a>
    <div class="meta">or write directly · <b>hi@impuls.studio</b> · <b>@impuls_studio</b></div>
  </section>
</Layout>

<style>
  .hero { padding: 160px 32px 80px; border-bottom: 1px solid var(--line); position: relative; overflow: hidden; }
  .crumbs { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .15em; margin-bottom: 80px; }
  .crumbs a:hover { color: var(--acid); }
  .crumbs span { margin: 0 10px; opacity: .4; }
  .hero h1 { font-family: 'Instrument Serif', serif; font-weight: 400; font-size: clamp(80px, 15vw, 260px); line-height: .82; letter-spacing: -.04em; margin-bottom: 48px; }
  .hero h1 em { font-style: italic; color: var(--acid); }
  .hero h1 .strike { position: relative; display: inline-block; }
  .hero h1 .strike::after { content: ""; position: absolute; left: -2%; right: -2%; top: 54%; height: 8px; background: var(--warm); transform: rotate(-1.5deg); }
  .hero-foot { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--line); }
  .hero-foot p { font-size: 20px; line-height: 1.5; max-width: 560px; }
  .hero-foot p span { color: var(--muted); }
  .hero-foot .meta { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .12em; color: var(--muted); line-height: 1.9; text-align: right; }
  .hero-foot .meta b { color: var(--ink); font-weight: 400; }

  .nums { display: grid; grid-template-columns: repeat(5, 1fr); border-bottom: 1px solid var(--line); }
  .num { padding: 48px 32px; border-right: 1px solid var(--line); }
  .num:last-child { border-right: 0; }
  .num .v { font-family: 'Instrument Serif', serif; font-size: clamp(48px, 5.5vw, 84px); line-height: 1; letter-spacing: -.03em; margin-bottom: 10px; }
  .num .v em { color: var(--acid); font-style: italic; }
  .num .v sup { font-size: .45em; color: var(--muted); vertical-align: top; font-style: normal; }
  .num .k { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: .13em; color: var(--muted); }

  section.s { padding: 140px 32px; border-bottom: 1px solid var(--line); }
  .s-grid { display: grid; grid-template-columns: 280px 1fr; gap: 60px; }
  .s-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .15em; color: var(--muted); position: sticky; top: 120px; align-self: start; }
  .s-tag::before { content: "§ "; color: var(--acid); }
  .s-body h2 { font-family: 'Instrument Serif', serif; font-size: clamp(48px, 6.5vw, 96px); font-weight: 400; letter-spacing: -.025em; line-height: .95; margin-bottom: 40px; }
  .s-body h2 em { color: var(--acid); font-style: italic; }
  .s-body p.big { font-family: 'Instrument Serif', serif; font-size: clamp(26px, 3vw, 42px); line-height: 1.2; letter-spacing: -.01em; max-width: 900px; margin-bottom: 28px; }
  .s-body p.big em { color: var(--acid); font-style: italic; }
  .s-body p { font-size: 17px; line-height: 1.55; max-width: 720px; margin-bottom: 18px; }

  .final { padding: 160px 32px; text-align: center; border-bottom: 1px solid var(--line); }
  .final h2 { font-family: 'Instrument Serif', serif; font-size: clamp(72px, 11vw, 180px); font-weight: 400; letter-spacing: -.035em; line-height: .85; margin-bottom: 48px; }
  .final h2 em { color: var(--acid); font-style: italic; }
  .final .cta { display: inline-flex; align-items: center; gap: 14px; padding: 22px 38px; background: var(--acid); color: #000; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-size: 13px; text-transform: uppercase; letter-spacing: .18em; font-weight: 600; transition: .2s; }
  .final .cta:hover { background: var(--ink); transform: translateY(-2px); }
  .final .meta { margin-top: 32px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .12em; }
  .final .meta b { color: var(--ink); font-weight: 400; }

  @media (max-width: 1000px) {
    .nums { grid-template-columns: 1fr 1fr; }
    .num { border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  }
  @media (max-width: 700px) {
    .hero-foot { grid-template-columns: 1fr; }
    .hero-foot .meta { text-align: left; }
    .s-grid { grid-template-columns: 1fr; }
    .s-tag { position: static; }
  }
</style>
