---
import '~/styles/pages/work.css';
import Layout from '~/layouts/Layout.astro';
import { localePath } from '~/i18n/utils';
import type { Locale } from '~/i18n/utils';
import { getCases, getPageIndex } from '~/lib/pocketbase';

interface Props { lang: Locale; }
const { lang } = Astro.props;

const [cases, pageIndex] = await Promise.all([getCases(lang), getPageIndex(lang)]);

const head = pageIndex?.work ?? { title: 'selected work.', em: 'work' };
const page = head.page ?? {};

// Counts
const total      = cases.length;
const liveCount  = cases.filter(c => c.status === 'live').length;
const byCategory = (cat: string) => cases.filter(c => c.category === cat).length;

const filters = (page.filters_categories ?? [
  { key: 'all',     label: 'all' },
  { key: 'trading', label: 'trading' },
  { key: 'brand',   label: 'brand' },
  { key: 'landing', label: 'landing' },
]) as { key: string; label: string }[];

const headTitleLead = (head.title ?? '').replace((head.em ?? '') + '.', '').replace((head.em ?? ''), '');
const endTitleLead = (page.end_title ?? '').replace((page.end_em ?? '') + '?', '').replace((page.end_em ?? ''), '');
---

<Layout lang={lang} active="work" withStickyCta={false} seo={page.seo}>
  <section class="ph">
    <div class="crumbs">
      <a href={localePath(lang, '/')}>index</a><span>/</span><span style="color:var(--ink)">work</span>
    </div>
    <h1 class="ph-title">{headTitleLead}<em>{head.em}</em>.</h1>
    <div class="ph-meta">
      <div>{page.archive_label ?? 'archive'} · <b>{total} / {page.archive_total ?? total}</b></div>
      <div>{page.span_label ?? 'span'} · <b>{page.span ?? ''}</b></div>
      <div>{page.filter_label ?? 'filter by tag / year / status'}</div>
    </div>
    <div class="ph-meta r">
      <div>{page.nda_label ?? 'under NDA'} · <b>{page.nda_hidden ?? 0} hidden</b></div>
      <div>{page.live_products ?? 'live products'} · <b>{liveCount}</b></div>
      <div>{page.next_slots ?? 'next slots'} · <b>{page.slots ?? ''}</b></div>
    </div>
  </section>

  <div class="filters">
    {filters.map((f, i) => {
      const count = f.key === 'all' ? total : byCategory(f.key);
      return <span class:list={['chip', { on: i === 0 }]}>{f.label} · {count}</span>;
    })}
    <div class="spacer"></div>
    <div class="view">{page.sort_label ?? 'sort / recent'} ↓</div>
  </div>

  <div class="list">
    {cases.map((c, i) => (
      <a href={localePath(lang, '/work/' + c.slug)} class="row">
        <span class="n">{String(i + 1).padStart(2, '0')}</span>
        <h3>{c.title} <span class="sub">{c.sub}</span></h3>
        <div class="tag-stack">
          {(c.tags ?? []).map((tag: string, idx: number) => idx === 0 ? <b>{tag}</b> : <span>{tag}</span>)}
        </div>
        <span class="year">{c.year}</span>
        <span class:list={['status', c.status]}>{c.status}</span>
        <span class="arr">↗</span>
      </a>
    ))}
  </div>

  <section class="end">
    <h2>{endTitleLead}<em>{page.end_em ?? 'similar'}</em>?</h2>
    <p>{page.end_text}</p>
    <a href={localePath(lang, '/') + '#start'} class="cta">{page.cta_label ?? 'start a project'} ↗</a>
  </section>
</Layout>
