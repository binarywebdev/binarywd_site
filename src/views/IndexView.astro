---
import '~/styles/pages/index.css';
import Layout from '~/layouts/Layout.astro';
import type { Locale } from '~/i18n/utils';
import { getCases, getServices, getDispatch, getPageIndex, getGlobals } from '~/lib/pocketbase';
import { dispatch as fxDispatch } from '~/lib/fixtures';

import Ticker from '~/sections/Ticker.astro';
import Hero from '~/sections/Hero.astro';
import Marquee from '~/sections/Marquee.astro';
import Services from '~/sections/Services.astro';
import SelectedWork from '~/sections/SelectedWork.astro';
import Manifest from '~/sections/Manifest.astro';
import Dispatch from '~/sections/Dispatch.astro';
import ContactForm from '~/sections/ContactForm.astro';

interface Props { lang: Locale; }
const { lang } = Astro.props;

// Все PB-запросы параллельно
const [featuredCases, servicesData, dispatchRaw, pageIndex, globals] = await Promise.all([
  getCases(lang).then(rows => rows.slice(0, 6)),
  getServices(lang),
  getDispatch(lang, 5),
  getPageIndex(lang),
  getGlobals(lang),
]);

// services → форма для <Services />
const services = servicesData.length
  ? servicesData.map((s: any) => ({
      title: s.title,
      tags: Array.isArray(s.tags) ? s.tags.join(' · ') : (s.tags ?? ''),
    }))
  : null;

// dispatch → форма {date, title, excerpt, tags, read}
const dispatchPosts = dispatchRaw.length
  ? dispatchRaw.map((p: any) => {
      const d = p.published_at ? new Date(p.published_at) : new Date();
      const dd = String(d.getUTCDate()).padStart(2, '0');
      const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
      const hh = String(d.getUTCHours()).padStart(2, '0');
      const mi = String(d.getUTCMinutes()).padStart(2, '0');
      return {
        date: { day: `${dd} / ${mm}`, full: `${d.getUTCFullYear()} · ${hh}:${mi} UTC` },
        title: p.title,
        excerpt: p.excerpt,
        tags: Array.isArray(p.tags) ? p.tags : [],
        read: `→ read ${p.read_minutes ?? 5} min`,
      };
    })
  : fxDispatch;

// Заголовки и подписи блока work — из globals (если есть), иначе мини-дефолты
const workHead = {
  title: pageIndex?.work?.title ?? 'selected work.',
  em:    pageIndex?.work?.em    ?? 'work',
  link:  pageIndex?.work?.link  ?? '2024 — 2026 / 12 cases',
};
---

<Layout lang={lang} seo={pageIndex?.seo}>
  <div class="glow"></div>

  <Ticker items={globals?.ticker_items} />
  <Hero lang={lang} data={pageIndex?.hero} />
  <Marquee items={pageIndex?.marquee} />
  <Services lang={lang} services={services} />
  <SelectedWork lang={lang} cases={featuredCases} head={workHead} />
  <Manifest lang={lang} data={pageIndex?.manifest} rules={globals?.manifest_rules} />
  <Dispatch lang={lang} posts={dispatchPosts} head={pageIndex?.dispatch?.head} filters={pageIndex?.dispatch?.filters} />
  <ContactForm lang={lang} data={pageIndex?.contact_form} />
</Layout>

<script>
  import '~/scripts/index-page';
</script>
