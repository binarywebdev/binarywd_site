---
import '~/styles/pages/case.css';
import Layout from '~/layouts/Layout.astro';
import { t, localePath } from '~/i18n/utils';
import type { Locale } from '~/i18n/utils';
import type { CaseRow } from '~/lib/fixtures';

interface Props { lang: Locale; case: CaseRow; }
const { lang, case: c } = Astro.props;
---

<Layout title={`${c.title} · Case · impuls/studio`} lang={lang} active="work" withStickyCta={false}>
  <div class="case">
    <div class="progress" id="progress"></div>

    <section class="hero">
      <div class="crumbs">
        <a href={localePath(lang, '/')}>index</a><span>/</span><a href={localePath(lang, '/work')}>work</a><span>/</span>
        <span style="color:var(--ink)">{c.slug}</span>
      </div>

      <div class="hero-grid">
        <div>
          <h1>{c.title.split(' ').slice(0, -1).join(' ')} <em>{c.title.split(' ').slice(-1)[0]}</em></h1>
          <p class="lede">{c.sub}.</p>
        </div>

        <div class="facts">
          <div class="fact"><span>client</span><b>—</b></div>
          <div class="fact"><span>year</span><b>{c.year.replace("'", "20")}</b></div>
          <div class="fact"><span>category</span><b>{c.category}</b></div>
          <div class="fact"><span>status</span><b class={c.status === 'live' ? 'live' : ''}>{c.status}</b></div>
        </div>
      </div>
    </section>

    <div class="bigvis">
      <div class="label"><b>{c.title}</b> · case visual</div>
    </div>

    <section class="s">
      <div class="s-grid">
        <div class="s-tag">[ 01 ] / context</div>
        <div class="s-body">
          <h2>case body — <em>port от reference</em></h2>
          <p>Это базовый шаблон кейса. Полный контент (problem ↔ solution, process steps, stats, gallery, quote, stack) подтянем из PocketBase, как только настроим коллекцию <code>cases</code> с полями <code>body_blocks</code>.</p>
          <p>Сейчас рендерится из <code>src/lib/fixtures.ts</code> — там <code>CaseRow</code> содержит только мета-поля. После миграции на PB этот же view будет получать <code>case.body</code> массивом блоков и разворачивать их.</p>
        </div>
      </div>
    </section>

    <section class="final">
      <h2>build something<br>that <em>compounds</em>.</h2>
      <a href={localePath(lang, '/') + '#start'} class="cta">{t(lang, 'common.startProject')} ↗</a>
    </section>
  </div>
</Layout>

<script>
  import '~/scripts/scroll-progress';
</script>
