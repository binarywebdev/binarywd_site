---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import StickyCta from '~/components/StickyCta.astro';
import type { Locale } from '~/i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  active?: 'work' | 'services' | 'about' | 'contact' | null;
  withFooter?: boolean;
  withStickyCta?: boolean;
}

const {
  title,
  description = 'impuls / studio — crypto-native design + dev',
  lang = (Astro.currentLocale as Locale) ?? 'ru',
  active = null,
  withFooter = true,
  withStickyCta = true
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;600&family=Inter:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav lang={lang} active={active} />

    <slot />

    {withFooter && <Footer lang={lang} />}
    {withStickyCta && <StickyCta lang={lang} />}
  </body>
</html>
