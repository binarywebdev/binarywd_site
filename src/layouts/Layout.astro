---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import StickyCta from '~/components/StickyCta.astro';
import SeoHead from '~/components/SeoHead.astro';
import type { Locale } from '~/i18n/utils';
import { getGlobals } from '~/lib/pocketbase';

interface Props {
  title?: string | null;
  lang?: Locale;
  active?: 'work' | 'services' | 'about' | 'contact' | null;
  withFooter?: boolean;
  withStickyCta?: boolean;
  seo?: any | null;
}

const {
  title = null,
  lang = (Astro.currentLocale as Locale) ?? 'ru',
  active = null,
  withFooter = true,
  withStickyCta = true,
  seo = null,
} = Astro.props;

const globals = await getGlobals(lang);
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <SeoHead lang={lang} seo={seo} defaults={globals?.seo_defaults} pathname={pathname} title={title} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;600&family=Inter:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav lang={lang} active={active} globals={globals} />

    <slot />

    {withFooter && <Footer lang={lang} globals={globals} />}
    {withStickyCta && <StickyCta lang={lang} />}
  </body>
</html>
