---
import CaseView from '~/views/CaseView.astro';
import { getCases, getCase } from '~/lib/pocketbase';

export async function getStaticPaths() {
  const cases = await getCases('en');
  return cases.map((c: any) => ({
    params: { slug: c.slug },
    props: { case: c }
  }));
}

const { case: cFromPath } = Astro.props;
const fresh = await getCase(cFromPath.slug, 'en');
const c = fresh ?? cFromPath;
---
<CaseView lang="en" case={c} />
